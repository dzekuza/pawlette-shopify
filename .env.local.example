# Copy to .env.local and fill in real values. Never commit .env.local.

# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_ACESS_TOKEN=
# The shop's public checkout domain (e.g. checkout.pawcharms.lt) — used by
# ShopifyAnalytics.tsx to scope the session-tracking cookie correctly. This is
# NOT the same as NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN (the .myshopify.com domain).
NEXT_PUBLIC_SHOPIFY_CHECKOUT_DOMAIN=
NEWSLETTER_DISCOUNT_CODE=LABAS10

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_PASSWORD=

# Meta Pixel + Conversions API (server-side event mirroring for ViewContent/AddToCart/InitiateCheckout)
# Pixel ID is not secret (it's already public in the client-side pixel snippet).
NEXT_PUBLIC_META_PIXEL_ID=
# Access token IS secret — generate in Events Manager > Settings > Conversions API. Server-only, never NEXT_PUBLIC_.
META_CAPI_ACCESS_TOKEN=

# Google Analytics 4
# Measurement ID is not secret (it's public in the client-side gtag snippet).
# GA4 is loaded DIRECTLY in code (src/app/layout.tsx) — this is the single
# source of truth. Do NOT also add a GA4 config tag for this ID inside the GTM
# container below, or pageviews/events are double-counted.
# If this is unset, GA4 does not load at all (no silent send to a wrong property).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CD28613MD9

# Google Tag Manager
# Container ID is not secret (it's already public in the client-side GTM snippet).
# Use GTM for non-GA4 tags only — GA4 is owned by the gtag block in code (see above).
NEXT_PUBLIC_GTM_ID=GTM-T6B2FJ5F
