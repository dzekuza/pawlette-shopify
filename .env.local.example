# Copy to .env.local and fill in real values. Never commit .env.local.

# Shopify Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_ACESS_TOKEN=
NEWSLETTER_DISCOUNT_CODE=LABAS10

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_PASSWORD=

# Meta Pixel + Conversions API (server-side event mirroring for ViewContent/AddToCart/InitiateCheckout)
# Pixel ID is not secret (it's already public in the client-side pixel snippet).
NEXT_PUBLIC_META_PIXEL_ID=
# Access token IS secret — generate in Events Manager > Settings > Conversions API. Server-only, never NEXT_PUBLIC_.
META_CAPI_ACCESS_TOKEN=

# Google Analytics 4 (gtag.js)
# Measurement ID is not secret (it's already public in the client-side gtag snippet).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CD28613MD9
